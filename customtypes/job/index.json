{
  "format": "custom",
  "id": "job",
  "label": "Job",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID"
        }
      },
      "title": {
        "type": "Text",
        "config": {
          "label": "Titre",
          "placeholder": "Titre de l'offre"
        }
      },
      "description": {
        "type": "StructuredText",
        "config": {
          "label": "Description",
          "placeholder": "Description de l'offre",
          "allowTargetBlank": true,
          "multi": "paragraph,strong,em,hyperlink,list-item,o-list-item"
        }
      },
      "publication_date": {
        "type": "Date",
        "config": {
          "label": "Date de publication",
          "placeholder": "Date de publication"
        }
      },
      "technologies": {
        "type": "Group",
        "config": {
          "label": "Technologies",
          "repeat": true,
          "fields": {
            "technology": {
              "type": "Text",
              "config": {
                "label": "Technology",
                "placeholder": "ex: React"
              }
            }
          }
        }
      },
      "admin_emails": {
        "type": "Group",
        "config": {
          "label": "Emails admin",
          "repeat": true,
          "fields": {
            "email": {
              "type": "Text",
              "config": {
                "label": "Email",
                "placeholder": "admin@example.com"
              }
            }
          }
        }
      }
    }
  }
}
